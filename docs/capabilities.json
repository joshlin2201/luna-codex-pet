  "identityTraits": [
    "real rabbit Luna, not a generic mascot",
    "compact low tucked loaf with steep raised gray haunch",
    "subtle lionhead mix cheek and neck ruff",
    "low dewlap wrapping over the tucked front legs",
    "head and chin sitting low into the dewlap instead of perched on a tall neck",
    "steep gray rear haunch when long hind legs are tucked",
    "long kicking and trailing rabbit hind feet when back legs extend",
    "mottled gray saddle and irregular side patch coat detail",
    "white blaze, white nose, white muzzle, and white chest",
    "dark gray-brown mask around both eyes with stronger viewer-left patch when front-facing",
    "quirky slightly squinty left eye",
    "gray saddle and side patches",
    "upright expressive asymmetric ears",
    "v3 cute illustrated renderer with all seventy-two atlas cells built from the behavior/anatomy spec"
  ],
  "anatomyRules": {
    "restingLoaf": [
      "legs tuck underneath the body",
      "head sits low into the dewlap/chest cushion",
      "dewlap and lionhead ruff envelop the front leg area",
      "tucked long hind legs create a compact shorter loaf with a steep raised gray haunch",
      "feet are hidden or barely visible under the chest",
      "silhouette stays long and low rather than round and upright"
    ],
    "visibleFeet": [
      "use rabbit feet only when motion requires it",
      "feet point downward, tucked, or outward from the body mass",
      "extended hind feet kick through toe-off and trail behind or to the side as long rabbit feet",
      "never draw paw pads, hands, fingers, dog feet, cat feet, short generic back paws, or arm-like forelegs"
    ],
    "actionMotion": [
      "directional movement uses rabbit hopping gait with forefeet reach, hindquarter load, hind-foot toe-off/kick, flight, and recovery",
      "jumping reads as a long-body binky with crouch, push-off, airborne extension, and settle",
      "compress frames show the steep tucked haunch and extension frames show long kicking/trailing hind feet",
      "expressive states should rely on ears, eyes, nose, head, ruff, and body compression"
    ]
  },
